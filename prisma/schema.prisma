// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DataReading {
  id                  Int      @id @default(autoincrement())
  timestamp           DateTime
  mc_voltage          Float?
  mc_thr_mv           Float?
  mc_motor_temp       Float?
  mc_motor_current    Int?
  mc_motor_torque     Int?
  mc_motor_power      Int?
  coolant_inlet_temp  Float?
  coolant_outlet_temp Float?
  gnss_latitude       Float?
  gnss_longitude      Float?
  gnss_speed          Int?
  gnss_track          Int?
}

model LogEntry {
  id        Int      @id @default(autoincrement())
  timestamp DateTime
  level     Int
  message   String
  emitter   String
  file      String?
  function  String?
  line      Int?
}

model SessionEntry {
  id        Int      @id @default(autoincrement())
  startTime DateTime
  endTime   DateTime
}

enum AlarmType {
  ERROR
  WARNING
  UNKNOWN
}

model AlarmEntry {
  pk             Int       @id @default(autoincrement())
  id             Int
  type           AlarmType
  message        String
  raisedAt       DateTime
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
}
